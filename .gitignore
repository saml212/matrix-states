.venv/
__pycache__/
*.pyc
*.egg-info/
.DS_Store

# Claude Code — share harness (hooks, scripts, schema, seed) across machines,
# gitignore everything else (runtime state, user-specific settings, worktrees).
.claude/*
!.claude/hooks/
!.claude/hooks/**
!.claude/scripts/
!.claude/scripts/**
!.claude/skills/
!.claude/skills/**
# But still ignore pycache etc. inside the allowlisted subtree
.claude/skills/**/__pycache__/
.claude/skills/**/*.pyc
!.claude/memory/
.claude/memory/*
!.claude/memory/schema.sql
!.claude/memory/.gitkeep
!.claude/settings.json
# .state/ is sentinel/runtime — not tracked
# settings.local.json is per-user (permissions allowlist) — do not track

# Empty results placeholders (real results live on SSD)
results/phase1/*.png
results/phase1/*.json
results/phase2/
results/phase3/

# Large training logs go on SSD, not in repo
# Override this for specific files by force-adding (git add -f)
experiment-runs/**/*.log
*.log

# Model checkpoints live on SSD
*.pt
*.bin
*.safetensors
.team-runs/

# ─── idastone harness block — managed by install.sh ────────────────────
# Do not edit between the BEGIN and END markers. install.sh will re-merge
# this block on upgrades. Rules outside the markers are yours and are
# preserved.

# BEGIN idastone
# Harness runtime — per-project state, never commit
.claude/memory/workflow.db
.claude/memory/workflow.db-*
.claude/memory/hook.log*
.claude/memory/ntfy_last_seen
.claude/memory/zcm_events.jsonl
.claude/memory/autopilot_events.jsonl
.claude/memory/autopilot.log
.claude/.state/
.team-runs/

# Shell-sourced / secret per-project configs — never commit
.claude/autopilot.conf
.claude/budget.toml
.claude/project_id
.claude/settings.local.json

# Agent scratch — drafts, temp plots, in-progress notes
.claude/_local/

# Secrets — defense-in-depth even if you have them elsewhere
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
id_ed25519*
id_ecdsa*
.netrc
credentials.json
credentials.yaml
secrets/
*.secret
service-account*.json

# ML artifacts — training outputs don't belong in the repo
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin
*.npz
checkpoints/
wandb/
mlruns/

# User-confidential — see docs/install.md "where things go"
_private/
**/_private/
docs/_internal/
**/*.private.md
NOTES_PRIVATE*
# END idastone

# Session/agent runtime dirs (not project content)
.agents/
.codex/
# LaTeX build artifacts (PDFs themselves ARE committed)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
matrix-thinking/submissions/**/*.log
# No file >25MB belongs in git — big payloads live on the SSD archive
